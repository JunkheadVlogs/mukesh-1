{
  "entities": {
    "ExitIntentLead": {
      "title": "ExitIntentLead",
      "description": "Lead captured from exit intent coupon popup",
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "description": "WhatsApp phone number of the lead"
        },
        "source": {
          "type": "string",
          "description": "Source of the lead capture"
        },
        "page": {
          "type": "string",
          "description": "Page URL where lead was captured"
        },
        "capturedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of capture"
        },
        "discountCode": {
          "type": "string",
          "description": "Discount code sent via WhatsApp"
        },
        "converted": {
          "type": "boolean",
          "description": "Whether lead has successfully purchased"
        }
      },
      "required": ["phone", "capturedAt"]
    }
  },
  "firestore": {
    "/exit_intent_leads/{leadId}": {
      "schema": "ExitIntentLead",
      "description": "Collection of exit intent leads captured"
    }
  }
}
